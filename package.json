{
  "name": "prosemeter-monorepo",
  "private": true,
  "type": "module",
  "description": "Monorepo for prosemeter — a deterministic scoring + feedback-loop layer for prose",
  "author": "jordan.burke@gmail.com",
  "license": "MIT",
  "homepage": "https://prosemeter.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanburke/prosemeter.git"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:check": "turbo run lint:check",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "typecheck": "turbo run typecheck",
    "validate": "turbo run validate",
    "dev": "turbo run dev",
    "clean": "pnpm -r clean && rm -rf .turbo",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "turbo": "^2.10.5"
  }
}
