    "retext-intensify": "^7.0.0",
    "retext-passive": "^5.0.0",
    "retext-redundant-acronyms": "^5.0.0",
    "retext-repeated-words": "^5.0.0",
    "retext-simplify": "^8.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@prosemeter/core": "workspace:^",
    "@types/nlcst": "^2.0.3",
    "@types/node": "^24.13.2",
    "ts-builds": "^3.2.1",
    "tsdown": "^0.22.5",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.20.0"
  }
