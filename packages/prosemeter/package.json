{
  "name": "prosemeter",
  "version": "0.1.0",
  "description": "Deterministic scoring + feedback-loop layer for prose — batteries-included bundle and CLI",
  "keywords": [
    "prose",
    "readability",
    "scoring",
    "fitness",
    "writing",
    "cli",
    "agents"
  ],
  "author": {
    "name": "Jordan Burke",
    "url": "https://github.com/jordanburke"
  },
  "license": "MIT",
  "homepage": "https://prosemeter.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanburke/prosemeter.git",
    "directory": "packages/prosemeter"
  },
  "bugs": {
    "url": "https://github.com/jordanburke/prosemeter/issues"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "NODE_ENV=production ts-builds build",
    "dev": "ts-builds dev",
    "prepublishOnly": "pnpm validate"
  },
  "bin": {
    "prosemeter": "dist/cli/index.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "prettier": "ts-builds/prettier",
  "dependencies": {
    "@prosemeter/core": "workspace:^",
    "@prosemeter/readability": "workspace:^",
    "functype": "^1.6.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "ts-builds": "^3.2.1",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.20.0"
  }
}
