{
  "name": "@prosemeter/core",
  "version": "0.1.0",
  "description": "prosemeter engine — parsing, dimension model, scoring math, profiles, and the loop contract",
  "keywords": [
    "prose",
    "readability",
    "scoring",
    "fitness",
    "prosemeter",
    "text-analysis"
  ],
  "author": {
    "name": "Jordan Burke",
    "url": "https://github.com/jordanburke"
  },
  "license": "MIT",
  "homepage": "https://github.com/jordanburke/prosemeter/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanburke/prosemeter.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/jordanburke/prosemeter/issues"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "NODE_ENV=production ts-builds build",
    "dev": "ts-builds dev",
    "prepublishOnly": "pnpm validate"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "prettier": "ts-builds/prettier",
  "dependencies": {
    "functype": "^1.6.2",
    "mdast-util-to-nlcst": "^7.0.1",
    "mdast-util-to-string": "^4.0.0",
    "nlcst-to-string": "^4.0.0",
    "parse-english": "^7.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "syllable": "^5.0.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "vfile": "^6.0.3"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/nlcst": "^2.0.3",
    "@types/node": "^26.1.0",
    "ts-builds": "^3.2.1",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.20.0"
  }
}
