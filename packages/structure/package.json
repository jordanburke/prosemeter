{
  "name": "@prosemeter/structure",
  "version": "0.2.0",
  "description": "prosemeter structure dimensions — heading hierarchy, section/paragraph length, document balance",
  "keywords": [
    "prose",
    "structure",
    "markdown",
    "mdast",
    "prosemeter"
  ],
  "author": {
    "name": "Jordan Burke",
    "url": "https://github.com/jordanburke"
  },
  "license": "MIT",
  "homepage": "https://github.com/jordanburke/prosemeter/tree/main/packages/structure#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordanburke/prosemeter.git",
    "directory": "packages/structure"
  },
  "bugs": {
    "url": "https://github.com/jordanburke/prosemeter/issues"
  },
  "scripts": {
    "validate": "ts-builds validate",
    "format": "ts-builds format",
    "format:check": "ts-builds format:check",
    "lint": "ts-builds lint",
    "lint:check": "ts-builds lint:check",
    "typecheck": "ts-builds typecheck",
    "test": "ts-builds test",
    "test:watch": "ts-builds test:watch",
    "test:coverage": "ts-builds test:coverage",
    "build": "NODE_ENV=production ts-builds build",
    "dev": "ts-builds dev",
    "prepublishOnly": "pnpm validate"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "prettier": "ts-builds/prettier",
  "peerDependencies": {
    "@prosemeter/core": ">=0.1.0"
  },
  "dependencies": {
