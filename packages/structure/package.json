    "mdast-util-to-string": "^4.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@prosemeter/core": "workspace:^",
    "@types/mdast": "^4.0.4",
    "@types/nlcst": "^2.0.3",
    "@types/node": "^24.13.2",
    "ts-builds": "^3.2.1",
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20.20.0"
  }
